# Server
PORT=3000
PUBLIC_BASE_URL=https://example.com
COMPANY_PHONE=000-0000-0000
BUSINESS_HOURS_TEXT=営業時間 9:00-18:00

# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Slack App
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0123456789
SLACK_PRESIDENT_USER_ID=U0123456789
SLACK_OFFICE_USER_ID=U0987654321

# 担当者名とSlackユーザーIDの対応表
# 例: {"佐藤":"U1111111111","田中":"U2222222222"}
SLACK_STAFF_USER_IDS={}

# Google Service Account
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=

# 例: ["primary","staff@example.com"]
# Simple: ["primary","staff@example.com"]
# Staff-aware: [{"id":"staff@example.com","name":"下村奈生カレンダー","staffName":"下村奈生"}]
GOOGLE_CALENDAR_IDS=[]
